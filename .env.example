# Copy to .env and fill in strong secrets (this file is committed; .env is not).
POSTGRES_USER=noblechat
POSTGRES_PASSWORD=change-me-strong-random
POSTGRES_DB=noblechat
DATABASE_URL=postgres://noblechat:change-me-strong-random@db:5432/noblechat

# Bearer token for the admin panel / admin API. Generate a long random value.
ADMIN_TOKEN=change-me-long-random

# Fixed seed for the mix-network topology. Keep it stable across restarts or all
# existing identities become invalid. Change it only for a fresh deployment.
NET_SEED=change-me-fixed-seed
