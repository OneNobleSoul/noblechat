# Copy to .env and fill in strong secrets (this file is committed; .env is not).
POSTGRES_USER=noblechat
POSTGRES_PASSWORD=change-me-strong-random
POSTGRES_DB=noblechat
DATABASE_URL=postgres://noblechat:change-me-strong-random@db:5432/noblechat

# Bearer token for the admin panel / admin API. Generate a long random value.
ADMIN_TOKEN=change-me-long-random

# Fixed seed for the mix-network topology. Keep it stable across restarts or all
# existing identities become invalid. Change it only for a fresh deployment.
NET_SEED=change-me-fixed-seed

# Shared secret authenticating internal mix-node <-> gateway traffic.
INTERNAL_TOKEN=change-me-long-random

# Host port the gateway is published on (loopback only). Change if 8790 is
# already in use on your machine.
HTTP_PORT=8790

# Optional: websocket url of the nym-client sidecar (compose service
# "nym-client"). Leave empty to run on the internal mix network only; the admin
# transport switch stays locked until this is set and the sidecar is connected.
# With the bundled sidecar: NYM_CLIENT_URL=ws://nym-client:1977
NYM_CLIENT_URL=

# Optional: TURN relay for calls stuck behind strict/symmetric NAT (public
# STUN alone can't find a peer-to-peer path there). Leave empty to stay
# STUN-only, exactly like before this existed. To turn it on: generate a long
# random secret, set it on both lines below, and point TURN_URIS at this
# host's public address on port 3478 (the bundled "coturn" compose service
# listens there). TURN_SHARED_SECRET must match between the app and coturn,
# which is why both read the same env var.
TURN_SHARED_SECRET=
# e.g. turn:chat.example.com:3478?transport=udp,turn:chat.example.com:3478?transport=tcp
TURN_URIS=

